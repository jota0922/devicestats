        color: var(--text-muted);
        margin: 0 0 1rem;
    }
    .hero h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 200;
        line-height: 1.45;
        margin: 0 0 1.25rem;
        letter-spacing: 0.04em;
    }
    .hero .lead {
        color: var(--text-muted);
        font-size: 1.02rem;
        font-weight: 300;
        margin: 0 auto 2.25rem;
        max-width: 540px;
        letter-spacing: 0.04em;
    }

    .cta {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .intro {
        padding: 2.25rem 2rem;
        max-width: 760px;
        margin: 2rem auto 0;
    }
    .intro h2 {
        margin-top: 1.75rem;
        font-size: 1.1rem;
        font-weight: 400;
        color: var(--text);
        letter-spacing: 0.06em;
