@page "/signup"
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>新規登録 - DeviceStats</PageTitle>

<div class="auth-wrap">
    <div class="page-head">
        <p class="eyebrow">Sign up</p>
        <h1>アカウント<span class="accent-text">作成</span></h1>
        <p class="lead">メールアドレスとパスワードで登録します。</p>
    </div>

    <div class="glass auth-card">
        <div class="field">
            <label for="email">メールアドレス</label>
            <input id="email" type="email" @bind="email" @bind:event="oninput" class="input" placeholder="you@example.com" />
        </div>

        <div class="field">
            <label for="pw">パスワード</label>
            <input id="pw" type="password" @bind="password" @bind:event="oninput" class="input" placeholder="6文字以上" />
        </div>

        @if (message != null)
        {
            <div class="msg @msgClass">@message</div>
        }

        <button class="btn btn-primary block" @onclick="HandleSubmit" disabled="@isBusy">
            @(isBusy ? "送信中..." : "新規登録する")
        </button>

        <div class="alt">
            すでにアカウントをお持ちですか？ <a href="login">ログイン</a>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? message;
    private string msgClass = "";
    private bool isBusy;

    private async Task HandleSubmit()
    {
        message = null;
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            message = "メールとパスワードを入力してください。";
            msgClass = "err";
            return;
        }
        if (password.Length < 6)
        {
            message = "パスワードは6文字以上にしてください。";
            msgClass = "err";
            return;
        }

        isBusy = true;
        var result = await Auth.SignUpAsync(email.Trim(), password);
        isBusy = false;

        if (result.Success)
        {
            message = "登録しました。確認メールが届く場合はリンクを開いてください。すでにログイン状態の場合は登録ページへ進めます。";
            msgClass = "ok";
            await Task.Delay(1200);
            Nav.NavigateTo("/register");
        }
        else
        {
            message = $"エラー：{result.Error}";
            msgClass = "err";
        }
    }
}

<style>
    .auth-wrap { max-width: 460px; margin: 0 auto; }
    .page-head { text-align: center; padding: 2rem 0; }
    .eyebrow { text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.75rem; color: var(--text-muted); margin: 0 0 0.75rem; }
    .page-head h1 { margin: 0 0 0.5rem; font-weight: 200; font-size: clamp(1.75rem, 4vw, 2.4rem); letter-spacing: 0.04em; }
    .page-head .lead { color: var(--text-muted); margin: 0; font-weight: 300; letter-spacing: 0.04em; }

    .auth-card { padding: 2rem; }

    .field { margin-bottom: 1.25rem; }
    label { display: block; font-size: 0.85rem; font-weight: 400; letter-spacing: 0.05em; color: var(--text); margin-bottom: 0.4rem; }
    .input {
        width: 100%;
        padding: 0.7rem 0.95rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        background: rgba(255, 255, 255, 0.7);
        border-radius: 12px;
        font-size: 0.95rem;
        font-weight: 300;
        font-family: inherit;
        color: var(--text);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .input:focus {
        outline: none;
        border-color: var(--accent-start);
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 0 0 3px rgba(106, 141, 255, 0.15);
    }

    .btn.block { width: 100%; padding: 0.85rem; font-size: 0.95rem; }
    .btn:disabled { opacity: 0.6; cursor: not-allowed; }

    .msg { margin-bottom: 1rem; padding: 0.8rem 1rem; border-radius: 12px; font-size: 0.88rem; font-weight: 300; }
    .msg.ok { background: rgba(106, 141, 255, 0.08); border: 1px solid rgba(106, 141, 255, 0.2); color: #2e4cb8; }
    .msg.err { background: rgba(217, 72, 95, 0.06); border: 1px solid rgba(217, 72, 95, 0.2); color: #b3344a; }

    .alt { margin-top: 1.25rem; text-align: center; font-size: 0.88rem; color: var(--text-muted); }
    .alt a { color: #4a6bd6; text-decoration: underline; }
</style>
